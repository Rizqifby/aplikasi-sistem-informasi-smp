<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none"
    tools:context=".profil.VisiMisiFragment">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:id="@+id/Rv_visi"
            android:layout_width="@dimen/_285sdp"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:background="@drawable/rectangle_scroll_profil"
            android:padding="10dp"
            android:layout_marginTop="@dimen/_10sdp"
            android:elevation="@dimen/_2sdp">
            <TextView
                android:id="@+id/tv_visi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visi"
                android:fontFamily="@font/roboto_bold"
                android:textSize="@dimen/_13ssp"
                android:textColor="@color/black" />
            <TextView
                android:layout_below="@id/tv_visi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/visi"
                android:fontFamily="@font/poppins_regular"
                android:textAlignment="center"
                android:textSize="@dimen/_11ssp"
                android:textColor="@color/black"
                android:layout_marginTop="@dimen/_5sdp"/>
        </RelativeLayout>

        <RelativeLayout
            android:layout_below="@id/Rv_visi"
            android:id="@+id/Rv_misi"
            android:layout_width="@dimen/_285sdp"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:background="@drawable/rectangle_scroll_profil"
            android:padding="10dp"
            android:layout_marginVertical="@dimen/_10sdp"
            android:elevation="@dimen/_2sdp">
            <TextView
                android:id="@+id/tv_misi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Misi"
                android:fontFamily="@font/roboto_bold"
                android:textSize="@dimen/_13ssp"
                android:textColor="@color/black" />
            <TextView
                android:id="@+id/tv_m1"
                android:layout_below="@id/tv_misi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/misi"
                android:fontFamily="@font/poppins_regular"
                android:textSize="@dimen/_11ssp"
                android:textColor="@color/black"
                android:layout_marginTop="@dimen/_5sdp"/>
        </RelativeLayout>

    </RelativeLayout>

</ScrollView>