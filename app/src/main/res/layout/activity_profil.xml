    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layoutProfil"
        android:layout_below="@id/tvIv_profil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/white"
        app:tabSelectedTextColor="@color/black"
        app:tabTextColor="#C6C6C6"
        app:tabIndicatorColor="@color/black"
        app:tabTextAppearance="@style/Iqbal"
        app:tabIndicatorHeight="@dimen/_2sdp">

        <com.google.android.material.tabs.TabItem
            android:id="@+id/identitas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IDENTITAS"/>
        <com.google.android.material.tabs.TabItem
            android:id="@+id/visiMisi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Visi &amp; Misi"/>
        <com.google.android.material.tabs.TabItem
            android:id="@+id/tu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tujuan"/>

    </com.google.android.material.tabs.TabLayout>

    <androidx.viewpager2.widget.ViewPager2
