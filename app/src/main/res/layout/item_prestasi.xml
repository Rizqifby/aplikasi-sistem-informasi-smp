<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/rectangle_menu"
    android:layout_marginTop="@dimen/_10sdp"
    android:layout_marginStart="15dp"
    android:layout_marginEnd="15dp"
    app:cardBackgroundColor="@color/white"
    android:layout_centerHorizontal="true">

    <RelativeLayout
        android:id="@+id/rv_foto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_img_juara"
            android:layout_width="@dimen/_60sdp"
            android:layout_height="@dimen/_75sdp"
            app:shapeAppearanceOverlay="@style/roundedImageStyle"
            android:scaleType="centerCrop"
            android:src="@drawable/prestasi3"
            android:layout_centerVertical="true" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/iv_img_juara"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/_10sdp">
            <TextView
                android:id="@+id/tv_kategori_juara"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="13dp"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@color/black"
                android:justificationMode="inter_word"/>
            <TextView
                android:id="@+id/tv_nama_juara"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="13dp"
                android:fontFamily="@font/roboto_medium"
                android:textColor="@color/black"/>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>