<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:clipToPadding="false"
    android:scrollbars="none"
    tools:context=".MainActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:backgroundTint="#fff">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/_118sdp"
            android:background="@drawable/rectangle_background_blue"
            android:backgroundTint="#D90889CB">
            <ImageView
                android:id="@+id/logo_spebra"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_50sdp"
                android:src="@drawable/logo_spebra"
                android:layout_alignParentLeft="true"
                android:layout_marginLeft="@dimen/_9sdp"
                android:layout_marginTop="@dimen/_15sdp"/>
            <TextView
                android:id="@+id/smpnegeri1brangsong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SMPN 1 BRANGSONG"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:fontFamily="@font/montserrat_bold"
                android:layout_alignParentLeft="true"
                android:layout_marginLeft="@dimen/_61sdp"
                android:layout_alignParentTop="true"
                android:layout_marginTop="@dimen/_15sdp"/>
            <TextView
                android:layout_below="@id/smpnegeri1brangsong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="spebra"
                android:textColor="@color/white"
                android:letterSpacing="0.1"
                android:textSize="18sp"
                android:fontFamily="@font/roboto_regular"
                android:layout_alignParentLeft="true"
                android:layout_marginLeft="@dimen/_61sdp"
                android:layout_marginTop="@dimen/_2sdp"/>
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/rectangle_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rectangle_menu"
            android:layout_alignParentLeft="true"
            android:layout_alignParentRight="true"
            android:layout_marginLeft="@dimen/_15sdp"
            android:layout_marginRight="@dimen/_15sdp"
            android:layout_marginTop="@dimen/_78sdp">

            <TextView
                android:id="@+id/menu_layanan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu Layanan"
                android:textColor="?android:textColorPrimary"
                android:fontFamily="@font/poppins_bold"
                android:textStyle="bold"
                android:textSize="17sp"
                android:layout_marginTop="@dimen/_3sdp"
                android:layout_marginLeft="@dimen/_13sdp"/>

            <TextView
                android:layout_below="@id/menu_layanan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih menu yang kamu butuhkan"
                android:textColor="?android:textColorPrimary"
                android:fontFamily="@font/lato_regular"
                android:textSize="12sp"
                android:layout_marginLeft="@dimen/_13sdp"/>

            <RelativeLayout
                android:id="@+id/menu1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_50sdp">
                
                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentLeft="true"
                        android:layout_marginLeft="@dimen/_22sdp">
                        
                        <RelativeLayout
                            android:id="@+id/profil"
                            android:layout_width="@dimen/_40sdp"
                            android:layout_height="@dimen/_38sdp"
                            android:background="@drawable/rectangle_small"
                            android:onClick="profil">

                            <ImageView
                                android:layout_width="@dimen/_31sdp"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:onClick="profil"
                                android:src="@drawable/profil" />
                        </RelativeLayout>
                        <TextView
                            android:layout_below="@id/profil"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_medium"
                            android:textStyle="bold"
                            android:layout_marginTop="@dimen/_8sdp"
                            android:layout_centerHorizontal="true"
                            android:text="Profil"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="13sp"/>
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true">

                        <RelativeLayout
                            android:id="@+id/pendidik"
                            android:layout_width="@dimen/_40sdp"
                            android:layout_height="@dimen/_38sdp"
                            android:background="@drawable/rectangle_small"
                            android:onClick="pendidik">

                            <ImageView
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:layout_centerInParent="true"
                                android:onClick="pendidik"
                                android:src="@drawable/pendidik" />
                        </RelativeLayout>
                        <TextView
                            android:layout_below="@id/pendidik"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_medium"
                            android:textStyle="bold"
                            android:layout_marginTop="@dimen/_8sdp"
                            android:layout_centerHorizontal="true"
                            android:text="Pendidik"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="13sp"/>
                    </RelativeLayout>

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_marginRight="@dimen/_22sdp">

                    <RelativeLayout
                        android:id="@+id/fasilitas"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_38sdp"
                        android:background="@drawable/rectangle_small"
                        android:onClick="fasilitas">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="35dp"
                            android:layout_centerInParent="true"
                            android:onClick="fasilitas"
                            android:src="@drawable/fasilitas" />
                    </RelativeLayout>
                    <TextView
                        android:layout_below="@id/fasilitas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/roboto_medium"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:layout_centerHorizontal="true"
                        android:text="Fasilitas"
                        android:textColor="@color/black"
                        android:textSize="13sp"/>
                </RelativeLayout>

            </RelativeLayout>

            <RelativeLayout
                android:layout_below="@id/menu1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/_9sdp">

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:layout_marginLeft="@dimen/_22sdp">

                    <RelativeLayout
                        android:id="@+id/ekskul"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_38sdp"
                        android:background="@drawable/rectangle_small"
                        android:onClick="ekskul"
                        android:layout_centerHorizontal="true">

                        <ImageView
                            android:layout_width="43dp"
                            android:layout_height="35dp"
                            android:layout_centerInParent="true"
                            android:onClick="ekskul"
                            android:src="@drawable/ekskul2" />
                    </RelativeLayout>
                    <TextView
                        android:layout_below="@id/ekskul"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/roboto_medium"
                        android:layout_centerHorizontal="true"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:text="Ekstra"
                        android:textColor="@color/black"
                        android:textSize="13sp"/>
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true">

                    <RelativeLayout
                        android:id="@+id/prestasi"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_38sdp"
                        android:background="@drawable/rectangle_small"
                        android:onClick="prestasi"
                        android:layout_centerHorizontal="true">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="35dp"
                            android:layout_centerInParent="true"
                            android:onClick="prestasi"
                            android:src="@drawable/prestasi" />
                    </RelativeLayout>
                    <TextView
                        android:layout_below="@id/prestasi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/roboto_medium"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:layout_centerHorizontal="true"
                        android:text="Prestasi"
                        android:textColor="@color/black"
                        android:textSize="13sp"/>
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_marginRight="@dimen/_22sdp">

                    <RelativeLayout
                        android:id="@+id/lainnya"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_38sdp"
                        android:background="@drawable/rectangle_small"
                        android:onClick="lainnya">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:onClick="lainnya"
                            android:src="@drawable/threedots" />
                    </RelativeLayout>
                    <TextView
                        android:layout_below="@id/lainnya"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/roboto_medium"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:layout_centerHorizontal="true"
                        android:text="Lainnya"
                        android:textColor="@color/black"
                        android:textSize="13sp"/>
                </RelativeLayout>

            </RelativeLayout>
                
        </RelativeLayout>

        <RelativeLayout
            android:layout_below="@id/rectangle_1"
            android:id="@id/menu_medsos"
            android:layout_width="340dp"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_alignParentRight="true"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginTop="@dimen/_15sdp">

            <TextView
                android:id="@+id/media_sosial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Sosial Media"
                android:textColor="?android:textColorPrimary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_below="@id/media_sosial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mari terhubung dengan kami"
                android:textColor="?android:textColorPrimary"
                android:fontFamily="@font/lato_regular"
                android:textSize="12sp"
                android:layout_marginLeft="5dp"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:paddingVertical="@dimen/_8sdp">

                <RelativeLayout
                    android:id="@+id/menu_instagram"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:layout_marginLeft="20dp"
                    android:onClick="instagram">

                    <RelativeLayout
                        android:id="@+id/Instagram"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/ellipse_2"
                        android:layout_centerHorizontal="true"
                        android:onClick="instagram">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="wrap_content"
                            android:layout_centerHorizontal="true"
                            android:src="@drawable/instagram2"
                            android:onClick="instagram"/>
                    </RelativeLayout>
                    <TextView
                        android:layout_below="@id/Instagram"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/ayar"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:layout_centerHorizontal="true"
                        android:text="Instagram"
                        android:textColor="@color/black"
                        android:textSize="15sp"/>
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/menu_facebook"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:onClick="facebook">

                    <RelativeLayout
                        android:id="@+id/facebook"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/ellipse_2"
                        android:layout_centerHorizontal="true"
                        android:onClick="facebook">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="wrap_content"
                           android:layout_centerHorizontal="true"
                            android:src="@drawable/facebook"
                            android:onClick="facebook"/>
                    </RelativeLayout>
                    <TextView
                        android:layout_below="@id/facebook"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/ayar"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:layout_centerHorizontal="true"
                        android:text="Facebook"
                        android:textColor="@color/black"
                        android:textSize="15sp"/>
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_marginRight="20dp"
                    android:onClick="email">

                    <RelativeLayout
                        android:id="@+id/email"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/ellipse_2"
                        android:layout_centerHorizontal="true"
                        android:onClick="email">
                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:src="@drawable/email" />
                    </RelativeLayout>
                    <TextView
                        android:layout_below="@id/email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/ayar"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:layout_centerHorizontal="true"
                        android:text="Email"
                        android:textColor="@color/black"
                        android:textSize="15sp"/>
                </RelativeLayout>

            </RelativeLayout>

        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/media_informasi"
            android:layout_below="@+id/menu_medsos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_marginTop="@dimen/_15sdp">

            <TextView
                android:id="@+id/tv_medsos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_marginLeft="@dimen/_10sdp"
                android:fontFamily="@font/poppins_bold"
                android:text="Galeri Kegiatan"
                android:textColor="?android:textColorPrimary"
                android:textSize="17sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="see all>"
                android:textColor="#A8A7A7"
                android:fontFamily="@font/poppins_regular"
                android:layout_alignParentRight="true"
                android:textSize="@dimen/_12sdp"
                android:onClick="seeall"
                android:layout_marginRight="@dimen/_10sdp"/>

        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:layout_below="@id/media_informasi"
            android:id="@+id/media"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_12sdp"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingRight="@dimen/_10sdp"/>


    </RelativeLayout>
</ScrollView>